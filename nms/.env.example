# === Database ===
POSTGRES_DB=nms
POSTGRES_USER=nms
POSTGRES_PASSWORD=nmspass
# Dari dalam container, host DB adalah nama service compose: db
DB_HOST=db
DB_PORT=5432

# === Collector ===
# Interval polling dalam detik
POLL_INTERVAL=60
# Timeout SNMP (detik) & retries
SNMP_TIMEOUT=5
SNMP_RETRIES=1

# === Alert engine ===
# Interval pengecekan alert (detik)
ALERT_CHECK_INTERVAL=60
# Jumlah sample berturut-turut di bawah threshold sebelum dianggap DOWN
CONSECUTIVE_DOWN_SAMPLES=3

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456:ABC-isi-token-bot-kamu
TELEGRAM_CHAT_ID=-1001234567890

# === Timezone untuk format waktu di notifikasi ===
TZ_DISPLAY=Asia/Jakarta

# === Dashboard web (Django) ===
# WAJIB diganti. Bikin acak: openssl rand -base64 48
DJANGO_SECRET_KEY=ganti-dengan-string-acak-panjang
DJANGO_DEBUG=0
# Host/IP yang boleh mengakses dashboard, pisahkan dengan koma.
# Contoh: 10.20.30.40,nms.internal
DJANGO_ALLOWED_HOSTS=*
# Isi kalau nanti diakses lewat HTTPS/reverse proxy, contoh: https://nms.internal
DJANGO_CSRF_TRUSTED_ORIGINS=
# Bind port dashboard. Pakai 127.0.0.1 kalau di belakang reverse proxy.
WEB_BIND=0.0.0.0

# === Fase 3 ===
# Berapa kali polling gagal berturut-turut sebelum perangkat dianggap mati.
# Satu perangkat mati menghasilkan SATU alert, bukan satu per pelanggan.
DEVICE_FAIL_THRESHOLD=3
# Kirim pengingat ke grup kalau gangguan major belum ditandai ditangani
# setelah sekian menit. Isi 0 untuk mematikan eskalasi.
ESCALATION_MINUTES=30
# Seberapa sering baseline traffic dihitung ulang (jam)
BASELINE_REFRESH_HOURS=6
